@model IEnumerable<CommunitySystem.Models.Marketplace.MarketplaceItem>

@{
    ViewData["Title"] = "Saved Listings";
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Marketplace</span>
        <h1 class="display-6 fw-semibold">Saved listings</h1>
        <p class="text-secondary mb-0">Items you bookmarked for later.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Marketplace</a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">No saved items yet.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                var thumb = item.Images.FirstOrDefault()?.ImagePath;
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrWhiteSpace(thumb))
                        {
                            <img src="@thumb" class="card-img-top" alt="@item.Title" style="aspect-ratio: 16/10; object-fit: cover;" />
                        }
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="fw-semibold">@item.Title</div>
                                <span class="badge text-bg-light rounded-pill">@item.ListingType</span>
                            </div>
                            <div class="text-secondary small">@(item.OwnerUser?.UserName ?? "User")</div>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div class="fw-semibold">RM @item.Price.ToString("0.00")</div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

