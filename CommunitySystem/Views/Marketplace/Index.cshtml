@model CommunitySystem.ViewModels.MarketplaceIndexViewModel
@using CommunitySystem.Models.Marketplace

@{
    ViewData["Title"] = "Marketplace";
    var q = ViewBag.SearchQuery as string;
    MarketplaceListingType? type = ViewBag.ListingType as MarketplaceListingType?;
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Community</span>
        <h1 class="display-6 fw-semibold">Marketplace</h1>
        <p class="text-secondary mb-0">Browse items for sale or rent from other residents.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Saved" class="btn btn-outline-secondary btn-iconed" title="Saved listings">
            <span class="btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M6 7h15l-1.5 9h-12L6 7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M9 7a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Saved
        </a>
        <a asp-action="MyListings" class="btn btn-outline-secondary btn-iconed">
            <span class="btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 6h13M8 12h13M8 18h13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M3.5 6h.5M3.5 12h.5M3.5 18h.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            My Listings
        </a>
        <a asp-action="Create" class="btn btn-primary btn-iconed">
            <span class="btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Create
        </a>
        <a asp-controller="MarketplaceChat" asp-action="Index" class="btn btn-outline-primary btn-iconed">
            <span class="btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M21 12a8 8 0 0 1-8 8H6l-3 3v-7a8 8 0 0 1 8-8h2a8 8 0 0 1 8 8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M8 12h8M8 16h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Chats
        </a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    <form method="get" class="d-flex flex-column flex-md-row gap-2 align-items-md-end mb-3">
        <div class="flex-grow-1">
            <label class="form-label text-secondary mb-1">Search</label>
            <input type="search" name="q" value="@q" class="form-control" placeholder="Search title or description..." autocomplete="off" />
        </div>
        <div style="min-width: 220px">
            <label class="form-label text-secondary mb-1">Type</label>
            <select class="form-select" name="type">
                <option value="">All</option>
                <option value="@((int)MarketplaceListingType.ForSale)" selected="@(type == MarketplaceListingType.ForSale)">For sale</option>
                <option value="@((int)MarketplaceListingType.ForRent)" selected="@(type == MarketplaceListingType.ForRent)">For rent</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-link text-decoration-none">Reset</a>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info mb-0">No items found.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.Items)
            {
                var thumb = item.Images.FirstOrDefault()?.ImagePath;
                var isSaved = Model.SavedItemIds.Contains(item.Id);
                var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrWhiteSpace(thumb))
                        {
                            <img src="@thumb" class="card-img-top" alt="@item.Title" style="aspect-ratio: 16/10; object-fit: cover;" />
                        }
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="fw-semibold">@item.Title</div>
                                <span class="badge text-bg-light rounded-pill">@item.ListingType</span>
                            </div>
                            <div class="text-secondary small">@item.Description</div>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div class="fw-semibold">RM @item.Price.ToString("0.00")</div>
                                <div class="d-flex gap-2">
                                    <form asp-action="ToggleSave" asp-route-id="@item.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit"
                                                class="btn btn-sm @(isSaved ? "btn-primary" : "btn-outline-secondary")"
                                                title="Save listing"
                                                aria-label="Save listing">
                                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                                                <path d="M6 7h15l-1.5 9h-12L6 7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                                <path d="M9 7a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            </svg>
                                        </button>
                                    </form>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer small text-secondary d-flex justify-content-between">
                            <span>@(item.OwnerUser?.UserName ?? "User")</span>
                            <span>@item.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
