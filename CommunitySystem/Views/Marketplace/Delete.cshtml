@model CommunitySystem.Models.Marketplace.MarketplaceItem

@{
    ViewData["Title"] = "Delete Listing";
    var thumb = Model.Images.FirstOrDefault()?.ImagePath;
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Marketplace</span>
        <h1 class="display-6 fw-semibold">Delete listing</h1>
        <p class="text-secondary mb-0">This action cannot be undone.</p>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back</a>
</div>

<div class="table-card p-3 p-lg-4">
    <div class="alert alert-warning">
        Are you sure you want to delete <span class="fw-semibold">@Model.Title</span>?
    </div>

    <div class="d-flex gap-3 align-items-start mb-3">
        @if (!string.IsNullOrWhiteSpace(thumb))
        {
            <img src="@thumb" alt="@Model.Title" style="width: 120px; height: 90px; object-fit: cover; border-radius: 12px; border: 1px solid rgba(0,0,0,.1);" />
        }
        <div>
            <div class="fw-semibold">@Model.Title</div>
            <div class="text-secondary">RM @Model.Price.ToString("0.00") · @Model.ListingType</div>
        </div>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>

