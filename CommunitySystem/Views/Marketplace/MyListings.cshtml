@model IEnumerable<CommunitySystem.Models.Marketplace.MarketplaceItem>

@{
    ViewData["Title"] = "My Listings";
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Marketplace</span>
        <h1 class="display-6 fw-semibold">My listings</h1>
        <p class="text-secondary mb-0">Manage items you created.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">Create Listing</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">You have no listings yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var thumb = item.Images.FirstOrDefault()?.ImagePath;
                    <tr>
                        <td>
                            <div class="d-flex align-items-start gap-3">
                                @if (!string.IsNullOrWhiteSpace(thumb))
                                {
                                    <img src="@thumb" alt="@item.Title" style="width: 72px; height: 54px; object-fit: cover; border-radius: 10px;" />
                                }
                                <div>
                                    <div class="fw-semibold">@item.Title</div>
                                    <div class="text-secondary small">@item.ListingType</div>
                                </div>
                            </div>
                        </td>
                        <td class="fw-semibold">RM @item.Price.ToString("0.00")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge text-bg-success rounded-pill">Active</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary rounded-pill">Inactive</span>
                            }
                        </td>
                        <td class="text-secondary">@item.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
