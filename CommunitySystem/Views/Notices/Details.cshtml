@model CommunitySystem.Models.Notice

@{
    ViewData["Title"] = "Notice Details";
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow notice-eyebrow">Formal Notice</span>
        <h1 class="display-6 fw-semibold notice-title">@Model.Title</h1>
        <p class="text-secondary mb-0">Published @Model.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Back To Home</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Notice</a>
        }
    </div>
</div>

<article class="notice-detail-card p-4 p-lg-5">
    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
    {
        <img src="@Model.ImagePath" alt="@Model.Title" class="notice-detail-image mb-4" />
    }
    <div class="d-flex flex-wrap gap-2 mb-4">
        @if (Model.IsFeatured)
        {
            <span class="badge notice-status-badge rounded-pill">Featured Notice</span>
        }
        @if (Model.IsPinned)
        {
            <span class="badge notice-status-badge rounded-pill">Pinned</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.AttachmentPath))
        {
            <a href="@Model.AttachmentPath" target="_blank" rel="noopener" class="notice-attachment-link">
                Download PDF: @(Model.AttachmentName ?? "Notice Attachment")
            </a>
        }
    </div>
    <div class="notice-body">
        <div class="notice-body-text">@Model.Content</div>
    </div>
</article>
