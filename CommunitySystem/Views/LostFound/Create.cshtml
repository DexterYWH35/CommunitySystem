@model CommunitySystem.ViewModels.LostFoundItemFormViewModel

@{
    ViewData["Title"] = "Report Lost or Found Item";
}

<section class="lf-shell">
    <div class="lf-banner mb-4">
        <div>
            <span class="lf-kicker">New Case</span>
            <h1>Register a lost or found item</h1>
            <p>If you found an item, leaving a phone number helps the admin team reconnect it to the rightful owner faster.</p>
            <div class="alert alert-warning mt-3 mb-0">
                <strong>Reminder:</strong> Please hand over any found items to <strong>REN Residences staff</strong> at the <strong>Lost &amp; Found counter</strong> (management office) for verification and collection.
            </div>
        </div>
    </div>

    <div class="lf-form-layout">
        <div class="lf-panel">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="ListingType" class="form-label"></label>
                <select asp-for="ListingType" asp-items="ViewBag.ListingTypeOptions" class="form-select"></select>
                <span asp-validation-for="ListingType" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Category" class="form-label"></label>
                <select asp-for="Category" asp-items="ViewBag.CategoryOptions" class="form-select"></select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LocationDetails" class="form-label"></label>
                <select asp-for="LocationDetails" asp-items="ViewBag.LocationOptions" class="form-select"></select>
                <span asp-validation-for="LocationDetails" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="IncidentDateUtc" class="form-label"></label>
                <input asp-for="IncidentDateUtc" class="form-control" />
                <span asp-validation-for="IncidentDateUtc" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="CustomLocationDetails" class="form-label"></label>
                <input asp-for="CustomLocationDetails" class="form-control" placeholder="Only fill this when you selected Other." />
                <span asp-validation-for="CustomLocationDetails" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="CustomCategory" class="form-label"></label>
                <input asp-for="CustomCategory" class="form-control" placeholder="Only fill this when you selected Other category." />
                <span asp-validation-for="CustomCategory" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ContactName" class="form-label"></label>
                <input asp-for="ContactName" class="form-control" />
                <span asp-validation-for="ContactName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ContactEmail" class="form-label"></label>
                <input asp-for="ContactEmail" class="form-control" />
                <span asp-validation-for="ContactEmail" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ContactPhone" class="form-label"></label>
                <input asp-for="ContactPhone" class="form-control" />
                <span asp-validation-for="ContactPhone" class="text-danger"></span>
                <div class="form-text">Recommended for found-item reports so the owner can be contacted faster.</div>
            </div>
            <div class="col-12">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>
                </div>
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <span class="lf-btn-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none">
                                <path d="M4 12l16-8-6.5 16-2.5-7L4 12z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        Submit Report
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <span class="lf-btn-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none">
                                <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        Cancel
                    </a>
                </div>
            </form>
        </div>

        <aside class="lf-sidecard">
            <h2 class="lf-section-title">Checklist</h2>
            <ul class="lf-checklist">
                <li>Use a clear title that helps others recognize the item quickly.</li>
                <li>Describe unique marks, color, size, or accessories.</li>
                <li>Include where the item was lost or found.</li>
                <li>Provide a phone number if you found the item and can be contacted directly.</li>
            </ul>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
