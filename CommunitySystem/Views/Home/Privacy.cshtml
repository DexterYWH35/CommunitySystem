@{
    ViewData["Title"] = "Privacy";
}

<div class="page-header mb-4">
    <span class="eyebrow">Policy</span>
    <h1 class="display-6 fw-semibold">Privacy and data handling</h1>
    <p class="text-secondary mb-0">This starter app stores local application data in SQLite for development and testing purposes.</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <p>
            The current version of CommunitySystem does not integrate with third-party APIs. Posts and comments are stored locally and can be extended later through the application's external integration service boundary.
        </p>
        <p class="mb-0">
            Before going live, document your production data retention, access control, and consent requirements here.
        </p>
    </div>
</div>
