@model List<CommunitySystem.Models.ComplaintCase>

@{
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = isAdmin ? "All Complaints" : "My Complaints";
    var searchTerm = ViewData["SearchTerm"] as string;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">@ViewData["Title"]</h1>
        <p class="text-secondary mb-0">
            @if (isAdmin)
            {
                <text>Review and manage complaints submitted by residents.</text>
            }
            else
            {
                <text>Track the status of the complaints you have submitted.</text>
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            <a asp-action="Dashboard" class="btn btn-outline-secondary">Dashboard</a>
        }
        <a asp-action="Create" class="btn btn-primary">New Complaint</a>
    </div>
</div>

<form method="get" class="d-flex flex-column flex-md-row gap-2 align-items-md-center mb-3">
    <div class="flex-grow-1">
        <label class="form-label mb-0 text-secondary">Search</label>
        <input type="search"
               name="q"
               value="@searchTerm"
               class="form-control"
               placeholder="Search title, location, labels..."
               autocomplete="off" />
    </div>
    <div class="d-flex gap-2 align-items-center">
        <label class="form-label mb-0 text-secondary">Label</label>
        <select class="form-select" name="labelId" asp-items="ViewBag.LabelFilterOptions" style="min-width: 220px;"></select>
    </div>
    <button type="submit" class="btn btn-outline-secondary">Filter</button>
    <a asp-action="Index" class="btn btn-link text-decoration-none">Reset</a>
</form>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No complaints found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
            <tr>
                <th>Title</th>
                <th class="d-none d-md-table-cell">Location</th>
                <th class="d-none d-lg-table-cell">Labels</th>
                <th>Status</th>
                <th class="text-end">Created</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold text-decoration-none">
                            @item.Title
                        </a>
                        <div class="text-secondary small">Case #@item.Id</div>
                    </td>
                    <td class="d-none d-md-table-cell">@item.LocationDetails</td>
                    <td class="d-none d-lg-table-cell">
                        @if (item.Labels.Count == 0)
                        {
                            <span class="text-secondary">—</span>
                        }
                        else
                        {
                            foreach (var link in item.Labels)
                            {
                                if (link.ComplaintLabel is null)
                                {
                                    continue;
                                }

                                <span class="badge bg-light text-dark border me-1">@link.ComplaintLabel.Name</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="badge @(item.Status == ComplaintCaseStatus.Completed ? "bg-success" : "bg-warning text-dark")">
                            @item.Status
                        </span>
                    </td>
                    <td class="text-end text-secondary">@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
