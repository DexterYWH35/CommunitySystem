@{
    ViewData["Title"] = "Chat with Admin";
    var threadId = ViewBag.ThreadId as int?;
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Support</span>
        <h1 class="display-6 fw-semibold">Chat with admin</h1>
        <p class="text-secondary mb-0">Ask questions or get help from the admin team.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Chats" asp-action="Index" class="btn btn-outline-secondary">All Chats</a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    @if (threadId is not null)
    {
        <a asp-action="Thread" asp-route-id="@threadId.Value" class="btn btn-primary">Open chat</a>
    }
    else
    {
        <div class="alert alert-info">No support chat yet.</div>
        <form asp-action="Start" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Start chat with admin</button>
        </form>
    }
</div>
