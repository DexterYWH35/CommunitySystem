@model IReadOnlyList<CommunitySystem.Models.SupportChat.SupportChatThread>

@{
    ViewData["Title"] = "Support Chats";
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Support</span>
        <h1 class="display-6 fw-semibold">Support chats</h1>
        <p class="text-secondary mb-0">Direct chats from residents.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Chats" asp-action="Index" class="btn btn-outline-secondary">All Chats</a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    @if (Model.Count == 0)
    {
        <div class="alert alert-info mb-0">No support chats yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Last activity</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var thread in Model)
                    {
                        var userName = thread.User?.UserName ?? thread.User?.Email ?? "User";
                        <tr>
                            <td>
                                <div class="fw-semibold">@userName</div>
                                <div class="text-secondary small">Thread #@thread.Id</div>
                            </td>
                            <td class="text-secondary">@((thread.LastMessageAtUtc ?? thread.CreatedAtUtc).ToLocalTime().ToString("dd MMM yyyy HH:mm"))</td>
                            <td class="text-end">
                                <a asp-action="Thread" asp-route-id="@thread.Id" class="btn btn-sm btn-outline-primary">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
