@model IEnumerable<CommunitySystem.Models.Marketplace.MarketplaceChatThread>

@{
    ViewData["Title"] = "Marketplace Chats";
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Marketplace</span>
        <h1 class="display-6 fw-semibold">Marketplace chats</h1>
        <p class="text-secondary mb-0">Conversations about marketplace items.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Chats" asp-action="Index" class="btn btn-outline-secondary">All Chats</a>
        <a asp-controller="Marketplace" asp-action="Index" class="btn btn-outline-secondary">Marketplace</a>
    </div>
</div>

<div class="table-card p-3 p-lg-4">
    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">No chats yet. Open an item and start a chat with the owner.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Participant</th>
                        <th>Last activity</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var thread in Model)
                {
                    var otherUser = thread.OwnerUserId == currentUserId ? thread.BuyerUser : thread.OwnerUser;
                    var otherName = otherUser?.UserName ?? otherUser?.Email ?? "User";
                    <tr>
                        <td>
                            <div class="fw-semibold">@(thread.MarketplaceItem?.Title ?? "Item")</div>
                            <div class="text-secondary small">Thread #@thread.Id</div>
                        </td>
                        <td>@otherName</td>
                        <td class="text-secondary">@((thread.LastMessageAtUtc ?? thread.CreatedAtUtc).ToLocalTime().ToString("dd MMM yyyy HH:mm"))</td>
                        <td class="text-end">
                            <a asp-action="Thread" asp-route-id="@thread.Id" class="btn btn-sm btn-outline-primary">Open</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
