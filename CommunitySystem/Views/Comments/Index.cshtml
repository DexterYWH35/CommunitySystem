@model IEnumerable<CommunitySystem.Models.Comment>
@using System.Security.Claims

@{
    ViewData["Title"] = "Comments";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Conversation</span>
        <h1 class="display-6 fw-semibold">Comments</h1>
        <p class="text-secondary mb-0">Review and manage all conversation activity across posts.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Comment</a>
</div>

<div class="table-card p-3 p-lg-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Comment</th>
                    <th>Author</th>
                    <th>Post</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Body</td>
                    <td>@item.AuthorName</td>
                    <td>@item.Post?.Title</td>
                    <td>@item.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td class="text-end">
                        <span class="badge text-bg-light rounded-pill me-2">@item.Likes.Count like(s)</span>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                        @if (isAdmin || item.OwnerUserId == currentUserId)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
