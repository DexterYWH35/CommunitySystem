@model CommunitySystem.ViewModels.CommentFormViewModel

@{
    ViewData["Title"] = "Create Comment";
}

<div class="page-header">
    <span class="eyebrow">Create</span>
    <h1 class="display-6 fw-semibold">New comment</h1>
    <p class="text-secondary mb-0">Attach a response to the right post and keep discussion organized.</p>
</div>

<div class="form-card p-4">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="PostId" class="form-label">Post</label>
                <select asp-for="PostId" asp-items="ViewBag.PostId" class="form-select"></select>
                <span asp-validation-for="PostId" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Body" class="form-label"></label>
                <textarea asp-for="Body" class="form-control"></textarea>
                <span asp-validation-for="Body" class="text-danger"></span>
            </div>
        </div>
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-primary">Save Comment</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
