@model CommunitySystem.ViewModels.PostDetailsViewModel
@using System.Security.Claims

@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Comments</h2>
        <span class="badge text-bg-light rounded-pill">@Model.Comments.Count</span>
    </div>

    @if (Model.Comments.Count == 0)
    {
        <div class="comment-card">
            <p class="mb-0 text-secondary">No comments yet. Start the conversation by adding the first one.</p>
        </div>
    }
    else
    {
        <div class="comment-list">
            @foreach (var comment in Model.Comments)
            {
                var canManageComment = User.IsInRole("Admin") || comment.OwnerUserId == currentUserId;
                <article class="comment-card">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                        <div>
                            <h3 class="h6 mb-1">@comment.AuthorName</h3>
                            <p class="small text-secondary mb-0">@comment.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap justify-content-end">
                            <form asp-controller="Comments" asp-action="ToggleLike" asp-route-id="@comment.Id" method="post" class="d-inline"
                                  data-ajax="true" data-ajax-kind="comment-like" data-comment-id="@comment.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-iconed @(comment.Likes.Any(like => like.UserId == currentUserId) ? "btn-primary" : "btn-outline-primary")">
                                    <span class="btn-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M12 21s-7-4.6-9.3-9C.8 8.1 3.1 5 6.7 5c2 0 3.4 1 4.3 2.2C11.9 6 13.3 5 15.3 5c3.6 0 5.9 3.1 4 7-2.3 4.4-9.3 9-9.3 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    <span data-like-text>@(comment.Likes.Any(like => like.UserId == currentUserId) ? "Unlike" : "Like")</span>
                                    <span class="ms-1" data-comment-like-count>@comment.Likes.Count</span>
                                </button>
                            </form>
                            <a asp-controller="Comments" asp-action="Details" asp-route-id="@comment.Id" class="btn btn-sm btn-outline-primary btn-iconed">
                                <span class="btn-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M2.5 12s3.5-7 9.5-7 9.5 7 9.5 7-3.5 7-9.5 7S2.5 12 2.5 12z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                        <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" stroke="currentColor" stroke-width="2"/>
                                    </svg>
                                </span>
                                View
                            </a>
                            @if (canManageComment)
                            {
                                <a asp-controller="Comments" asp-action="Edit" asp-route-id="@comment.Id" class="btn btn-sm btn-outline-secondary btn-iconed">
                                    <span class="btn-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M4 20h4l10.5-10.5a2 2 0 0 0 0-3L16.5 4a2 2 0 0 0-3 0L3 14.5V20z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    Edit
                                </a>
                                <a asp-controller="Comments" asp-action="Delete" asp-route-id="@comment.Id" class="btn btn-sm btn-outline-danger btn-iconed">
                                    <span class="btn-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M6 7h12M10 7V5h4v2m-7 0l1 14h8l1-14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    Delete
                                </a>
                            }
                        </div>
                    </div>
                    <p class="mb-0">@comment.Body</p>
                </article>
            }
        </div>
    }
</section>

<br />
<section class="form-card p-4 mb-4">
    <form asp-action="AddComment" asp-route-id="@Model.Post.Id" method="post" data-ajax="true" data-ajax-kind="post-comments" data-ajax-target="#post-comments">
        <input type="hidden" asp-for="NewComment.PostId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="NewComment.Body" class="form-label"></label>
            <textarea asp-for="NewComment.Body" class="form-control" placeholder="Write your comment here..."></textarea>
            <span asp-validation-for="NewComment.Body" class="text-danger"></span>
        </div>
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary btn-iconed">
                <span class="btn-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M21 12a8 8 0 0 1-8 8H7l-4 3V12a8 8 0 0 1 8-8h2a8 8 0 0 1 8 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    </svg>
                </span>
                Post Comment
            </button>
        </div>
    </form>
</section>
