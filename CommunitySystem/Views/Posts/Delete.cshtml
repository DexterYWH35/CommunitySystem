@model CommunitySystem.Models.Post

@{
    ViewData["Title"] = "Delete Post";
}

<div class="page-header">
    <span class="eyebrow">Delete</span>
    <h1 class="display-6 fw-semibold">Delete post</h1>
    <p class="text-secondary mb-0">This will also remove all comments linked to the post.</p>
</div>

<div class="detail-card p-4">
    <h2 class="h4">@Model.Title</h2>
    <p class="text-secondary">@Model.ContentPreview</p>
    <dl class="row mb-4">
        <dt class="col-sm-3">Author</dt>
        <dd class="col-sm-9">@Model.AuthorName</dd>
        <dt class="col-sm-3">Comments</dt>
        <dd class="col-sm-9">@Model.Comments.Count</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-danger">Delete Post</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
