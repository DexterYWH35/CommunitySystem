@model CommunitySystem.ViewModels.PostDetailsViewModel
@using System.Security.Claims

@{
    ViewData["Title"] = "Post Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canManagePost = User.IsInRole("Admin") || Model.Post.OwnerUserId == currentUserId;
}

<div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
    <div>
        <span class="eyebrow">Post</span>
        <h1 class="display-6 fw-semibold">@Model.Post.Title</h1>
        <p class="text-secondary mb-0">By @Model.Post.AuthorName · @Model.Post.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index"
           class="btn btn-outline-secondary btn-iconed"
           onclick="if (window.history.length > 1) { window.history.back(); return false; }">
            <span class="btn-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            Back
        </a>
        @if (canManagePost)
        {
            <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-outline-secondary btn-iconed">
                <span class="btn-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M4 20h4l10.5-10.5a2 2 0 0 0 0-3L16.5 4a2 2 0 0 0-3 0L3 14.5V20z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    </svg>
                </span>
                Edit Post
            </a>
        }
    </div>
</div>

<div class="detail-card p-4 mb-4">
    @if (!string.IsNullOrWhiteSpace(Model.Post.ImagePath))
    {
        <img src="@Model.Post.ImagePath" alt="@Model.Post.Title" class="post-image-detail mb-4" />
    }
    <div class="post-content mb-0">@Model.Post.Content</div>
    <div class="d-flex flex-wrap align-items-center gap-3 mt-4">
        <form asp-action="ToggleLike" asp-route-id="@Model.Post.Id" method="post" class="d-inline"
              data-ajax="true" data-ajax-kind="post-like">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-iconed @(Model.HasLikedPost ? "btn-primary" : "btn-outline-primary")">
                <span class="btn-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 21s-7-4.6-9.3-9C.8 8.1 3.1 5 6.7 5c2 0 3.4 1 4.3 2.2C11.9 6 13.3 5 15.3 5c3.6 0 5.9 3.1 4 7-2.3 4.4-9.3 9-9.3 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span data-like-text>@(Model.HasLikedPost ? "Unlike Post" : "Like Post")</span>
            </button>
        </form>
        <span id="post-like-count" class="badge text-bg-light rounded-pill">@Model.PostLikeCount like(s)</span>
    </div>
</div>

<div id="post-comments">
    <partial name="_PostComments" model="Model" />
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
