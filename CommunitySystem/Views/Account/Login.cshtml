@model CommunitySystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell">
    <section class="auth-panel auth-panel--brand">
        <span class="eyebrow">Welcome Back</span>
        <h1 class="display-6 fw-semibold mt-3 mb-3">Sign in to access Ren Residence Community services.</h1>
        <p class="text-secondary mb-4">
            Continue where you left off: posts &amp; discussions, Lost &amp; Found, complaints, and the community marketplace.
        </p>
        <div class="auth-feature-grid">
            <div class="auth-feature-card">
                <div class="auth-feature-title">Services</div>
                <div class="auth-feature-body">Lost &amp; Found · Complaints</div>
            </div>
            <div class="auth-feature-card">
                <div class="auth-feature-title">Marketplace</div>
                <div class="auth-feature-body">Sell/Rent listings · QR payment sharing</div>
            </div>
            <div class="auth-feature-card">
                <div class="auth-feature-title">Stay updated</div>
                <div class="auth-feature-body">Notifications · Chat</div>
            </div>
        </div>
    </section>

    <section class="auth-panel auth-panel--form">
        <div class="auth-header">
            <span class="eyebrow">Account</span>
            <h2 class="h3 mt-3 mb-2">Login</h2>
            <p class="text-secondary mb-0">
                Use your account to access community features. Marketplace transactions are between users—review the disclaimer in
                <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>.
            </p>
        </div>

        <form asp-action="Login" method="post" class="mt-4">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <div class="d-grid gap-3">
                <button type="submit" class="btn btn-primary btn-lg">Login</button>
                <a asp-action="Register" class="btn btn-outline-primary">Create an account</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
