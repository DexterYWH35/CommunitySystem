@model CommunitySystem.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="auth-shell">
    <section class="auth-panel auth-panel--brand">
        <span class="eyebrow">Join The Portal</span>
        <h1 class="display-6 fw-semibold mt-3 mb-3">Create a user account and start contributing to the community space.</h1>
        <p class="text-secondary mb-4">
            Registered users can create their own posts, manage their own updates, and participate in conversations across the portal.
        </p>
        <div class="auth-highlights">
            <div class="stat-card">
                <span class="stat-label">Posting</span>
                <strong>Create and manage your own content</strong>
            </div>
            <div class="stat-card">
                <span class="stat-label">Discussion</span>
                <strong>Comment across community posts</strong>
            </div>
        </div>
    </section>

    <section class="auth-panel auth-panel--form">
        <div class="auth-header">
            <span class="eyebrow">Account</span>
            <h2 class="h3 mt-3 mb-2">Register</h2>
            <p class="text-secondary mb-0">New accounts are created as standard users by default.</p>
        </div>

        <form asp-action="Register" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <div class="d-grid gap-3">
                <button type="submit" class="btn btn-primary btn-lg">Create Account</button>
                <a asp-action="Login" class="btn btn-outline-primary">Already have an account?</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
